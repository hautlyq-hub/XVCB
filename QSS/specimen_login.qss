{
	border: 2px solid transparent;
	color: #000000;
	background-color :#F3F3F3;
}
QDialog#mvRecallPatientData QDateEdit#FromDateEdit:hover,
QDialog#mvRecallPatientData QDateEdit#ToDateEdit:hover
{
	border:2px solid qlineargradient(spread:reflect, x1:0.0, y1:0.0, x2:1.0, y2:0.0, stop:0 rgba(249, 104, 174, 255), stop:1 rgba(30,81,241, 255));
}
QDialog#mvRecallPatientData QDateEdit#FromDateEdit::down-arrow:hover,
QDialog#mvRecallPatientData QDateEdit#ToDateEdit::down-arrow:hover,
QDialog#mvRecallPatientData QDateEdit#FromDateEdit::down-arrow,
QDialog#mvRecallPatientData QDateEdit#ToDateEdit::down-arrow,
QDialog#mvRecallPatientData QDateEdit#FromDateEdit::down-arrow:disabled,
QDialog#mvRecallPatientData QDateEdit#ToDateEdit::down-arrow:disabled,
QDialog#mvRecallPatientData QDateEdit#FromDateEdit::drop-down,
QDialog#mvRecallPatientData QDateEdit#ToDateEdit::drop-down
{
	width:40px;
	height:84px;
        image:url(:/Res/Image/common/18.png);
	border:0px solid qlineargradient(spread:reflect, x1:0.0, y1:0.0, x2:1.0, y2:0.0, stop:0 rgba(249, 104, 174, 255), stop:1 rgba(30,81,241, 255));
	background-position:center;background-repeat:repeat;

}
QDialog#mvRecallPatientData QDateEdit#FromDateEdit:disabled,
QDialog#mvRecallPatientData QDateEdit#ToDateEdit:disabled
{
    color:#D9D9D9;
}




