QWidget#lyWifiConectWidgetClass QTableView
{  
    color:#000000; 
	alternate-background-color: #F3F3F3;
	background-color:  #F3F3F3;
	border: 0px solid transparent; 
	gridline-color: transparent; 
    border-radius: 0px; 
    padding: 0px;
	margin: 0px;
	outline:0px;

}
QWidget#lyWifiConectWidgetClass QTableView QHeaderView,
QWidget#lyWifiConectWidgetClass QTableView QHeaderView::section
{
	border:none;
	text-align:center;
    background-color: qlineargradient(spread:reflect, x1:1, y1:0.5, x2:1, y2:1, stop:0 rgba(203, 203, 203, 255), stop:1 rgba(255, 255, 255, 255));
    color: #000000;
	outline:0px;
}
QWidget#lyWifiConectWidgetClass QTableView:hover
{
	border: 0px solid transparent; 
}
QWidget#lyWifiConectWidgetClass QTableView::item:selected,
QWidget#lyWifiConectWidgetClass QTableView::branch:selected
{ 
	color:#FFFFFF;
	background-color: qlineargradient(spread:reflect, x1:1, y1:0.5, x2:1, y2:1, stop:0 rgba(0, 156, 255, 255), stop:1 rgba(255, 255, 255, 255));
	/* background:#009CFF; */
	outline: 0px;
	border:0px;
}





