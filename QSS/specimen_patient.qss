QDateEdit#FromDateEdit_2,
QDateEdit#ToDateEdit_2
{
        border: 1px solid transparent;
	color: #000000;
	background-color :#FFFFFF;
}
QDateEdit#FromDateEdit_2:hover,
QDateEdit#ToDateEdit_2:hover
{
        border:1px solid qlineargradient(spread:reflect, x1:0.0, y1:0.0, x2:1.0, y2:0.0, stop:0 rgba(249, 104, 174, 255), stop:1 rgba(30,81,241, 255));
}
QDateEdit#FromDateEdit_2::down-arrow:hover,
QDateEdit#ToDateEdit_2::down-arrow:hover,
QDateEdit#FromDateEdit_2::down-arrow,
QDateEdit#ToDateEdit_2::down-arrow,
QDateEdit#FromDateEdit_2::down-arrow:disabled,
QDateEdit#ToDateEdit_2::down-arrow:disabled,
QDateEdit#FromDateEdit_2::drop-down,
QDateEdit#ToDateEdit_2::drop-down
{
        width:35px;
        height:35px;
        image:url(:/Res/Image/common/18.png);
	border:0px solid qlineargradient(spread:reflect, x1:0.0, y1:0.0, x2:1.0, y2:0.0, stop:0 rgba(249, 104, 174, 255), stop:1 rgba(30,81,241, 255));
	background-position:center;background-repeat:repeat;

}
QDateEdit#FromDateEdit_2:disabled,
QDateEdit#ToDateEdit_2:disabled
{
    color:#D9D9D9;
}

QWidget#lyCreateDICOMDIR QPushButton#m_buttonExamineDisk,
QWidget#lyCreateDICOMDIR QPushButton#m_buttonExamineDisk:hover,
QWidget#lyCreateDICOMDIR QPushButton#m_buttonExamineDisk:checked 
{
	background-color:#F3F3F3;
	border:0px solid transparent;
	border-radius:0px;
}




QWidget#lyCreateDICOMDIR QLineEdit,
QWidget#lyCreateDICOMDIR QLineEdit:hover
{
	padding-left:5px;
    border:1px solid #FFFFFF;
	background-color: #F3F3F3;
	color:#000000;
}
QWidget#lyCreateDICOMDIR QLineEdit:disabled
{
   background-color: #FFFFFF;
   color:#D9D9D9;
}


QWidget#lyCreateDICOMDIR QToolButton:hover,
QWidget#lyCreateDICOMDIR QToolButton
{
    background-color: transparent;
	color: #000000;
    border: 0px solid transparent;
    margin: 2px;
    padding: 2px;
	border-radius:0px;
}
QWidget#lyCreateDICOMDIR QToolButton:pressed,
QWidget#lyCreateDICOMDIR QToolButton:checked
{
	color: #000000;
    background-color: qlineargradient(spread:reflect, x1:0.0, y1:0.0, x2:0.0, y2:1.0, stop:0 rgba(255, 255, 255, 0), stop:1 rgba(249, 104, 174, 255));
	border: 0px solid transparent;
}
QWidget#lyCreateDICOMDIR QToolButton:disabled
{
	color: #D3D3D3;
}
