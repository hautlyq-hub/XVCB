


QWidget#mSysMaintWidget QFrame#mFrmMaintainTitle
{
    background-color: qlineargradient(spread:reflect, x1:0.0, y1:0.0, x2:1.0, y2:0.0, stop:0 rgba(0, 156, 255, 255), stop:1 rgba(30,81,241, 255));
	Color:#000000;
}


QWidget#mSysMaintWidget QPushButton#mExpMgnt,
QWidget#mSysMaintWidget QPushButton#mReviseMgnt,
QWidget#mSysMaintWidget QPushButton#mCameraMgnt,
QWidget#mSysMaintWidget QPushButton#mDebugMgnt,
QWidget#mSysMaintWidget QPushButton#mLineReportMgnt
{
	background-color: transparent;
    border: 0px solid qlineargradient(spread:reflect, x1:0.0, y1:0.0, x2:1.0, y2:0.0, stop:0 rgba(249, 104, 174, 255), stop:1 rgba(30,81,241, 255));
    color: #FFFFFF;
    padding: 0px;
    outline: none;
	border-radius:0px;
}
