QWidget#mSysMaintWidget QTabBar::tab
{
    background-color: #FFFFFF;
	Color: #000000;
	border: 0px solid #FFFFFF;
    border-bottom-color:transparent;
    border-top-left-radius: 0px;
    border-top-right-radius:0px;
    width:250px;
    min-height: 70px;
    max-height: 70px;
}
QWidget#mSysMaintWidget QTabWidget::tab-bar
{
    alignment: left;
}
QWidget#mSysMaintWidget QTabBar::tab:hover 
{
    background-color: #FFFFFF;
	border: 0px solid #143FC5;
}
QWidget#mSysMaintWidget QTabBar::tab:selected
{
    background-color: #143FC5;
    color: #FFFFFF;
	border: 0px solid #143FC5;
}
QWidget#mSysMaintWidget QTabBar::tab:!selected 
{
    background-color:#FFFFFF;
    color:#000000;
}
QWidget#mSysMaintWidget QTabBar::tab:disabled 
{
	width: 0; 
	color: transparent;
}





