QTableView
{
        color:#000000;
        alternate-background-color:qlineargradient(spread:reflect, x1:1, y1:0.5, x2:1, y2:1, stop:0 rgba(233, 233, 233, 100), stop:1 rgba(255, 255, 255, 255));
        background-color: #F3F3F3;
        border: 0px solid transparent;
        gridline-color: transparent;
        border-radius: 0px;
        padding: 0px;
        margin: 0px;
        outline:0px;
        font-family: "Microsoft YaHei";
        font-size:10pt;

}
QTableView QHeaderView,
QTableView QHeaderView::section
{
        border:none;
        text-align:center;
        background-color: qlineargradient(spread:reflect, x1:0.0, y1:0.0, x2:0.0, y2:1.0, stop:0 rgba(249, 104, 174, 255), stop:1 rgba(30,81,241, 255));
        color: #FFFFFF;
        outline:0px;
        font-size:10pt;
        font-family: "Microsoft YaHei";

}
QTableView:hover
{
        border: 0px solid transparent;
}
QTableView::item:selected,
QTableView::branch:selected
{
        color:#FFFFFF;
        background-color: qlineargradient(spread:reflect, x1:1, y1:0.5, x2:1, y2:1, stop:0 rgba(0, 156, 255, 255), stop:1 rgba(255, 255, 255, 255));
        /* background:#009CFF; */
        outline: 0px;
        border:0px;
}




QTableWidget
{
        color:#000000;
        alternate-background-color: #F3F3F3;
        background-color:  #F3F3F3;
        border: 0px solid transparent;
        gridline-color: transparent;
        border-radius: 0px;
        padding: 0px;
        margin: 0px;
