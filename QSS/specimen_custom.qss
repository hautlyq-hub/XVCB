QTimeEdit,QDoubleSpinBox,QSpinBox
{
        border: 1px solid transparent;
        color: #000000;
        background-color :#FFFFFF;
        padding-left:0px;
        padding-right:0px;
}
QTimeEdit:hover,QDoubleSpinBox:hover,QSpinBox:hover
{
        border: 1px solid qlineargradient(spread:reflect, x1:0.0, y1:0.0, x2:1.0, y2:0.0, stop:0 rgba(249, 104, 174, 255), stop:1 rgba(30,81,241, 255));
        color: #000000;
}
QTimeEdit:disabled,QDoubleSpinBox:disabled,QSpinBox:disabled
{
    background-color: #D9D9D9;
    color:#FFFFFF;
}
QTimeEdit::up-button,QDoubleSpinBox::up-button,QSpinBox::up-button
{
    image: url(:/Res/Image/common/152.png);
    width: 40px;
    height: 40px;
}
QTimeEdit::down-button,QDoubleSpinBox::down-button,QSpinBox::down-button
{
    image: url(:/Res/Image/common/151.png);
    width: 40px;
    height: 40px;
}
QTimeEdit::up-button:hover,QDoubleSpinBox::up-button:hover,QSpinBox::up-button:hover,
QTimeEdit::up-button:pressed,QDoubleSpinBox::up-button:pressed,QSpinBox::up-button:pressed
{
    image: url(:/Res/Image/common/153.png);
    width: 40px;
    height: 40px;
}

QTimeEdit::down-button:hover,QDoubleSpinBox::down-button:hover,QSpinBox::down-button:hover,
QTimeEdit::down-button:pressed,QDoubleSpinBox::down-button:pressed,QSpinBox::down-button:pressed
{
    image: url(:/Res/Image/common/154.png);
    width: 40px;
    height: 40px;
}

QTimeEdit::up-button:disabled,QDoubleSpinBox::up-button:disabled,QSpinBox::up-button:disabled
{
    image: url(:/Res/Image/common/156.png);
    width: 40px;
    height: 40px;    }
QTimeEdit::down-button:disabled,QDoubleSpinBox::down-button:disabled,QSpinBox::down-button:disabled
{
    image: url(:/Res/Image/common/155.png);
    width: 40px;
    height: 40px;
}







QListView
{
        color:#FFFFFF;
        outline:0px;
        padding:0px;
        background-color:#F3F3F3;
}
QListView::item
{
        color:#000000;
        margin:2px;
        height:30px;
        font-size:10pt;
        font-family: "Microsoft YaHei";
}
QListView::item:hover,QListView::item:focus
{
    background-color: qlineargradient(spread:reflect, x1:0.0, y1:0.0, x2:1.0, y2:0.0, stop:0 rgba(0, 156, 255, 255), stop:1 rgba(30,81,241, 255));
        color: #F3F3F3;
}
QListView::item:pressed
{
    background-color: qlineargradient(spread:reflect, x1:0.0, y1:0.0, x2:1.0, y2:0.0, stop:0 rgba(0, 156, 255, 255), stop:1 rgba(30,81,241, 255));
        color: #F3F3F3;
}

