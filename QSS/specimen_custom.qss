* {
    font-family: "Microsoft YaHei";
}

QWidget
{
        Color:#000000;
        background-color:#F3F3F3;
    background-clip: border;
    border-image: none;
    border: 0px solid transparent;
    outline: none;
        padding:0px;
}
QDialog
{
        Color:#000000;
        background-color:#FFFFFF;
        background-clip: border;
        border-image: none;
        border: 0px solid transparent;
        outline: none;
        padding:0px;
}

QWidget:focus
{
        outline: none;
}

QTableView:focus
{
        outline: none;
}

QFrame:focus
{
        Color:#000000;
        background-color:#F3F3F3;
    background-clip: border;
    border-image: none;
    border: 0px solid transparent;
    outline: none;
        padding:0px;
}

QDialog:focus
{
        outline: none;
}

QWidget[whatsThis="lyFrm"],
QFrame[whatsThis="lyFrm"],
QDialog[whatsThis="lyFrm"]
{
        Color:#000000;
        background-color:#FFFFFF;
    background-clip: border;
    border-image: none;
    border: 0px solid transparent;
    outline: none;
        padding:0px;
}


QDialog
{
        Color:#000000;
        background-color:#FFFFFF;
        border: 10pt solid transparent;
}


QLabel
{
        background-color:transparent;
        color:#000000;
        border: 0px solid transparent;
}

/*通用按钮*/
QPushButton ,
QPushButton:hover
{
    background-color: qlineargradient(spread:reflect, x1:0.0, y1:0.0, x2:1.0, y2:0.0, stop:0 rgba(0, 156, 255, 255), stop:1 rgba(30,81,241, 255));
    border: 0px solid transparent;
    color: #FFFFFF;
    padding: 0px;
        border:0px;
    outline: none;
        border-radius:10px;
}

QPushButton:pressed ,
QPushButton:checked
{
    background-color: #143FC5;
        color: #FFFFFF;
}
QPushButton:disabled
{
    background-color: #D9D9D9;
        color:#FFFFFF;
}

/*彩色常用按钮*/
QWidget QPushButton[whatsThis="lyBtn"],
QDialog QPushButton[whatsThis="lyBtn"],
QWidget QPushButton[whatsThis="lyBtn"]:hover,
QDialog QPushButton[whatsThis="lyBtn"]:hover
{
    background-color: qlineargradient(spread:reflect, x1:0.0, y1:0.0, x2:1.0, y2:0.0, stop:0 rgba(249, 104, 174, 255), stop:1 rgba(30,81,241, 255));
    border: 0px solid transparent;
    color: #FFFFFF;
    padding: 0px;
        border:0px;
    outline: none;
        border-radius:10px;
}

QWidget QPushButton[whatsThis="lyBtn"]:pressed ,
QWidget QPushButton[whatsThis="lyBtn"]:checked ,
QDialog QPushButton[whatsThis="lyBtn"]:pressed ,
QDialog QPushButton[whatsThis="lyBtn"]:checked
{
    background-color: #143FC5;
        color: #FFFFFF;
}
QWidget QPushButton[whatsThis="lyBtn"]:disabled ,
QDialog QPushButton[whatsThis="lyBtn"]:disabled
{
    background-color: #D9D9D9;
        color:#FFFFFF;
}


