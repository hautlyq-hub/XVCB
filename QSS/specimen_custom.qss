QCheckBox,QRadioButton
{
    background-color: transparent;
    color: #000000;
    outline:0px;
}
QCheckBox::indicator,
QRadioButton::indicator
{
    width: 30px;
    height: 30px;
}

QCheckBox::indicator:unchecked,
QRadioButton::indicator:unchecked
{
    image: url(:/Res/Image/common/252.png);
}

QCheckBox::indicator:checked,
QRadioButton::indicator:checked
{
    image: url(:/Res/Image/common/251.png);
}
QCheckBox:disabled,QRadioButton:disabled
{
        background-color: transparent;
        color: #D9D9D9;
}


QWidget QComboBox
{
    border: 1px solid transparent;
    background: #FFFFFF;
        Color:#000000;
        margin:0px;

}
QWidget QComboBox:hover
{
    border: 1px solid qlineargradient(spread:reflect, x1:0.0, y1:0.0, x2:1.0, y2:0.0, stop:0 rgba(249, 104, 174, 255), stop:1 rgba(30,81,241, 255));
}
QWidget QComboBox QAbstractItemView
{
        color:#FFFFFF;
        outline:0px;
        padding:0px;
        background-color:#FFFFFF;
}
QWidget QComboBox QAbstractItemView::item
{
        color:#000000;
        margin:2px;
        height:30px;
}
QWidget QComboBox QAbstractItemView::item:hover,QComboBox QAbstractItemView::item:focus
{
    background-color: qlineargradient(spread:reflect, x1:0.0, y1:0.0, x2:1.0, y2:0.0, stop:0 rgba(0, 156, 255, 255), stop:1 rgba(30,81,241, 255));
        color: #FFFFFF;
}
QWidget QComboBox QAbstractItemView::item:pressed
{
    background-color: qlineargradient(spread:reflect, x1:0.0, y1:0.0, x2:1.0, y2:0.0, stop:0 rgba(0, 156, 255, 255), stop:1 rgba(30,81,241, 255));
        color: #FFFFFF;
}
QWidget QComboBox::drop-down
{
        /*下拉箭头宽度*/
    width:40px;
    border:0px solid qlineargradient(spread:reflect, x1:0.0, y1:0.0, x2:1.0, y2:0.0, stop:0 rgba(249, 104, 174, 255), stop:1 rgba(30,81,241, 255));
}
QWidget QComboBox::down-arrow:hover
{
        /*图像宽度*/
        width:40px;
        height:40px;
        border-image:url(:/Res/Image/common/250.png);
        background-position:center;background-repeat:repeat;
}
QWidget QComboBox::down-arrow
{
        /*图像宽度*/
        width:40px;
        height:40px;
        border-image:url(:/Res/Image/common/250.png);
        background-position:center;background-repeat:repeat;
}
QWidget QComboBox:disabled
{
   background-color: #FFFFFF;
   color: #D9D9D9;
}



