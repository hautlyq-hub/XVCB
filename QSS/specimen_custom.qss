/*标题TableBar*/
QCalendarWidget
{
        font-family:"Microsoft YaHei";
        font-size: 10pt;
        min-width:250px;
        min-height:220px;
        Color:#1E51F1;
        background-color: #D9D9D9 ;
}
QCalendarWidget QWidget#qt_calendar_navigationbar
{
                font-family:"Microsoft YaHei";
        font-size: 10pt;
        min-height:40px;
        Color:#1E51F1;
        background-color: #D9D9D9 ;
}
/*月按钮*/
QCalendarWidget QToolButton#qt_calendar_monthbutton
{
        font-family:"Microsoft YaHei";
        font-size: 10pt;
        min-width:50px;
        min-height:20px;
    padding-right: 3px;
}
/*年按钮*/
QCalendarWidget QToolButton#qt_calendar_yearbutton
{
        font-family:"Microsoft YaHei";
        font-size: 10pt;
    background: transparent;
        min-width:80px;
        color:#000000;
}
/*上一月*/
QCalendarWidget QToolButton#qt_calendar_prevmonth
{
        background-color: transparent;
        min-width: 35px;
        border-image: url(:/Res/Image/common/159.png);
        qproperty-icon:url();
        background-position:center;background-repeat:repeat;
}
/*下一月*/
QCalendarWidget QToolButton#qt_calendar_nextmonth
{
        background-color: transparent;
        min-width: 35px;
        border-image: url(:/Res/Image/common/160.png);
        qproperty-icon:url();
        background-position:center;background-repeat:repeat;
}
/* 本月天 */
QCalendarWidget QAbstractItemView:enabled
{
        alternate-background-color:#f3f3f3;
        background-color: #FFFFFF;
        color: #000000;
        selection-color: #FFFFFF;
        selection-background-color: #1E51F1;
        font: 10pt;
        outline:none;
}
/* 其他月天 */
QCalendarWidget QAbstractItemView:disabled
{
    color:#A0A094;
        outline:none;
}
QCalendarWidget QSpinBox
{
        width:150px;
}






QProgressBar
{
        background: #D3D3D3;
    border: 0px solid transparent;
    margin:0px;
        padding:0px;
    border-radius: 12px;
}
QProgressBar:chunk
{
    border: 0px solid transparent;
        background-color:qlineargradient(spread:reflect, x1:0.0, y1:0.0, x2:1.0, y2:0.0, stop:0 rgba(249, 104, 174, 255), stop:1 rgba(30,81,241, 255));
    margin: 0px;
        padding:0px;
        border-radius: 12px;
}



QScrollBar:vertical
{
width:30px;
padding-top:30px;
padding-bottom:30px;
}

QScrollBar:horizontal
{
height:30px;
padding-left:30px;
padding-right:30px;
}

